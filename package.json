{
  "name": "vector-frankl",
  "version": "1.0.0-beta.1",
  "description": "High-performance vector database that runs entirely in the browser using IndexedDB",
  "keywords": [
    "vector",
    "database",
    "indexeddb",
    "embeddings",
    "similarity-search",
    "vector-search",
    "browser",
    "typescript",
    "ai",
    "machine-learning",
    "hnsw",
    "webgpu",
    "simd",
    "wasm"
  ],
  "homepage": "https://github.com/stevekinney/vector-frankl#readme",
  "bugs": {
    "url": "https://github.com/stevekinney/vector-frankl/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevekinney/vector-frankl.git"
  },
  "license": "MIT",
  "author": "Steve Kinney <hello@stevekinney.net>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/index.js"
    },
    "./gpu": {
      "types": "./dist/gpu.d.ts",
      "import": "./dist/gpu.js",
      "require": "./dist/cjs/gpu.js",
      "default": "./dist/gpu.js"
    },
    "./workers": {
      "types": "./dist/workers.d.ts",
      "import": "./dist/workers.js",
      "require": "./dist/cjs/workers.js",
      "default": "./dist/workers.js"
    },
    "./debug": {
      "types": "./dist/debug.d.ts",
      "import": "./dist/debug.js",
      "require": "./dist/cjs/debug.js",
      "default": "./dist/debug.js"
    },
    "./benchmarks": {
      "types": "./dist/benchmarks.d.ts",
      "import": "./dist/benchmarks.js",
      "require": "./dist/cjs/benchmarks.js",
      "default": "./dist/benchmarks.js"
    },
    "./compression": {
      "types": "./dist/compression.d.ts",
      "import": "./dist/compression.js",
      "require": "./dist/cjs/compression.js",
      "default": "./dist/compression.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "bun run build:clean && bun run build:types && bun run build:js && bun run build:cjs",
    "build:cjs": "bun build --target=browser --outdir=dist/cjs --format=cjs --minify --sourcemap=external ./src/index.ts ./src/gpu.ts ./src/workers.ts ./src/debug.ts ./src/benchmarks.ts ./src/compression.ts",
    "build:clean": "rm -rf dist",
    "build:js": "bun build --target=browser --outdir=dist --format=esm --minify --sourcemap=external ./src/index.ts ./src/gpu.ts ./src/workers.ts ./src/debug.ts ./src/benchmarks.ts ./src/compression.ts",
    "build:types": "tsc -p tsconfig.build.json",
    "check:env": "bun run scripts/check-environment.ts",
    "clean": "bun run scripts/clean.ts",
    "dev": "bun --watch run src/index.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepack": "bun run build",
    "prepare": "husky",
    "prepublishOnly": "bun run lint && bun run typecheck && bun run test && bun run build",
    "start": "bun run dist/index.js",
    "test": "bun test src tests/unit tests/compression tests/debug tests/gpu tests/integration tests/search tests/vectors tests/wasm tests/workers tests/debug-mock.test.ts",
    "test:all": "bun run test && bun run test:end-to-end",
    "test:coverage": "bun test --coverage src tests/unit tests/compression tests/debug tests/gpu tests/integration tests/search tests/vectors tests/wasm tests/workers tests/debug-mock.test.ts",
    "test:end-to-end": "playwright test",
    "test:end-to-end:chromium": "playwright test --project=chromium",
    "test:end-to-end:firefox": "playwright test --project=firefox",
    "test:end-to-end:headed": "playwright test --headed",
    "test:end-to-end:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:end-to-end:ui": "playwright test --ui",
    "test:end-to-end:webkit": "playwright test --project=webkit",
    "test:parallel": "bun test --parallel src tests/unit tests/compression tests/debug tests/gpu tests/integration tests/search tests/vectors tests/wasm tests/workers tests/debug-mock.test.ts",
    "test:watch": "bun test --watch src tests/unit tests/compression tests/debug tests/gpu tests/integration tests/search tests/vectors tests/wasm tests/workers tests/debug-mock.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "src/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "eslint --fix"
    ],
    "scripts/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "eslint --fix"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ],
    "package.json": [
      "sort-package-json"
    ]
  },
  "dependencies": {
    "zod": "^3.25.17"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^7.5.1",
    "@playwright/test": "^1.53.2",
    "@types/bun": "^1.2.13",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "bun-plugin-tailwind": "^0.0.15",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-typescript": "^4.3.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-regexp": "^3.0.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^16.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "playwright": "^1.53.2",
    "prettier": "^3.5.3",
    "sort-package-json": "^3.2.1",
    "typescript-eslint": "^8.56.1"
  },
  "engines": {
    "bun": ">=1.13.0",
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
